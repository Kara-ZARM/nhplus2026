<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>

<!--
  STUB-Vorlage für die Pfleger-Übersicht (AB 04, Workstream B).

  Dieses Skelett liefert TableView, Eingabefelder und Buttons. Was noch fehlt
  und von euch ergänzt werden muss:

    1. fx:controller="de.hitec.nhplus.controller.AllCaregiverController"
       oben im <AnchorPane>-Tag ergänzen, sobald euer Controller existiert. [x]

    2. onAction- und onEditCommit-Handler an Buttons und TableColumns
       eintragen (siehe AllPatientView.fxml als Vorlage).

    3. Spalten und Eingabefelder an die Akzeptanzkriterien eurer User
       Stories aus AB 03 anpassen — der Stub zeigt nur Beispielspalten,
       welche Attribute eine Pflegekraft hat, entscheidet eure Planung.

  Orientiert euch beim Ausfüllen an AllPatientView.fxml — gleicher Aufbau,
  nur andere Domäne.
-->

<AnchorPane prefHeight="500.0" prefWidth="855.0" stylesheets="@Application.css" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="de.hitec.nhplus.controller.AllCaregiverController">
    <children>
        <TableView fx:id="tableView" editable="true" layoutX="31.0" layoutY="40.0" AnchorPane.bottomAnchor="150.0"
                   AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="80.0">
            <columns>
                <TableColumn fx:id="columnId" maxWidth="1200.0" minWidth="5.0" prefWidth="5.0" text="ID"/>
                <TableColumn fx:id="columnSurname" maxWidth="7500.0" minWidth="20.0" onEditCommit="#handleOnEdit" prefWidth="100.0" text="Nachname"/>
                <TableColumn fx:id="columnFirstName" maxWidth="7500.0" onEditCommit="#handleOnEdit" prefWidth="75.0" text="Vorname"/>
                <TableColumn fx:id="columnPhoneNumber" maxWidth="7500.0" onEditCommit="#handleOnEdit" prefWidth="75.0" text="Telefonnummer"/>
                <TableColumn fx:id="columnDateOfBirth" maxWidth="7500.0" onEditCommit="#handleOnEdit" prefWidth="75.0" text="Geburtstag"/>
                <TableColumn fx:id="columnStreet" maxWidth="7500.0" onEditCommit="#handleOnEdit" prefWidth="75.0" text="Straße"/>
                <TableColumn fx:id="columnPostalCode" maxWidth="7500.0" onEditCommit="#handleOnEdit" prefWidth="75.0" text="Postleitzahl"/>
                <TableColumn fx:id="columnCity" maxWidth="7500.0" onEditCommit="#handleOnEdit" prefWidth="75.0" text="Stadt"/>
                <TableColumn fx:id="columnTaxId" maxWidth="7500.0" onEditCommit="#handleOnEdit" prefWidth="75.0" text="Steuerklasse"/>
                <TableColumn fx:id="columnQualification" maxWidth="7500.0" onEditCommit="#handleOnEdit" prefWidth="75.0" text="Qualifikation"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
        <HBox fx:id="HboxInsert" layoutX="623.0" layoutY="419.3999938964844" spacing="10.0" AnchorPane.bottomAnchor="15.0"
              AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0">
            <children>
                <GridPane hgap="10.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" prefWidth="200.0"/>
                        <ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" minWidth="200.0" prefWidth="200.0"/>
                        <ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="160.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                    </rowConstraints>
                    <children>
                        <TextField fx:id="textFieldSurname" minWidth="150.0" prefHeight="26.0" prefWidth="200.0" promptText="Nachname" GridPane.columnIndex="1"/>
                        <TextField fx:id="textFieldFirstName" minWidth="150.0" prefHeight="26.0" prefWidth="200.0" promptText="Vorname" />
                        <TextField fx:id="textFieldPhoneNumber" minWidth="150.0" prefHeight="26.0" prefWidth="200.0" promptText="Telefonnummer" GridPane.columnIndex="2"/>
                        <TextField fx:id="textFieldDateOfBirth" minWidth="150.0" prefHeight="26.0" prefWidth="200.0" promptText="Geburtsdatum" GridPane.rowIndex="1"/>
                        <TextField fx:id="textFieldStreet" minWidth="150.0" prefHeight="26.0" prefWidth="200.0" promptText="Straße" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <TextField fx:id="textFieldPostalCode" minWidth="150.0" prefHeight="26.0" prefWidth="200.0" promptText="Postleitzahl" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <TextField fx:id="textFieldCity" minWidth="150.0" prefHeight="26.0" prefWidth="200.0" promptText="Stadt" GridPane.rowIndex="2"/>
                        <TextField fx:id="textFieldTaxId" minWidth="150.0" prefHeight="26.0" prefWidth="200.0" promptText="Steuerklasse" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        <TextField fx:id="textFieldQualification" minWidth="150.0" prefHeight="26.0" prefWidth="200.0" promptText="Qualifikation" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                    </children>
                    <padding>
                        <Insets right="10.0"/>
                    </padding>
                    <HBox.margin>
                        <Insets/>
                    </HBox.margin>
                </GridPane>
                <HBox alignment="TOP_RIGHT" prefWidth="190.0" spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Button fx:id="buttonAdd" mnemonicParsing="false" onAction="#handleAdd" prefWidth="80.0" text="Hinzufügen" />
                        <Button fx:id="buttonDelete" mnemonicParsing="false" onAction="#handleDelete" prefWidth="80.0" text="Löschen" />
                    </children>
                </HBox>
            </children>
        </HBox>
        <HBox alignment="TOP_CENTER" layoutX="10.0" layoutY="10.0" prefWidth="200.0" spacing="25.0"
              AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">
            <children>
                <Label alignment="CENTER" contentDisplay="CENTER" minWidth="400.0" text="Pfleger*innen"
                       textAlignment="CENTER">
                    <font>
                        <Font size="36.0"/>
                    </font>
                </Label>
            </children>
        </HBox>
    </children>
    <padding>
        <Insets top="10.0"/>
    </padding>
</AnchorPane>
